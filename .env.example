# Adobe I/O Runtime credentials
# Run `aio login` and `aio app use` to configure your org/project/workspace.
# The aio CLI writes runtime credentials to ~/.aio — you do not need to set them here manually.

# Log level for the MCP action (debug | info | warn | error)
LOG_LEVEL=debug

# Optional: override runtime namespace and auth for CI/CD pipelines
# AIO_RUNTIME_NAMESPACE=your-namespace
# AIO_RUNTIME_AUTH=your-auth-token
