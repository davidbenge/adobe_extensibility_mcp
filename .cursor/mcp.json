{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "Adobe Developer Assistant (ADA)": {
      "url": "https://ada.adobe.io/api/v2/ada/mcp",
      "transport": "streamable-http"
    },
    "Adobe Wiki Confluence": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "adobe-wiki-confluence-fghlo",
        "--env-file",
        "~/.easymcp/adobe-mcp-servers/src/adobe-wiki/.env",
        "adobe-wiki-confluence"
      ]
    },
    "NewRelic MCP Server": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "newrelic-mcp-server-hvrmj",
        "--env-file",
        "~/.easymcp/adobe-mcp-servers/src/new-relic/.env",
        "newrelic-mcp-server"
      ]
    },
    "Spectrum Vars MCP Server": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "spectrum-vars-mcp-server-gxblr",
        "spectrum-vars-mcp-server"
      ]
    },
    "I18n MCP Server": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "in-mcp-server-scpwk",
        "--env-file",
        "~/.easymcp/adobe-mcp-servers/src/i18n/.env",
        "in-mcp-server"
      ]
    },
    "React Spectrum S2": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "react-spectrum-s-ndfgp",
        "react-spectrum-s"
      ]
    },
    "Corp Jira": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "corp-jira-ydana",
        "--env-file",
        "~/.easymcp/adobe-mcp-servers/src/corp-jira/.env",
        "corp-jira"
      ]
    },
    "Corp GitHub": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "corp-github-iehac",
        "--env-file",
        "~/.easymcp/adobe-mcp-servers/src/corp-github/.env",
        "corp-github"
      ]
    }
  }
}
