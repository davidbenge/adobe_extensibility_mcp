{
  "name": "adobe-extensibility-mcp",
  "version": "1.0.0",
  "description": "A remote MCP server deployed on Adobe I/O Runtime that serves a curated library of Adobe developer skills — covering App Builder actions, frontend patterns, and Workfront APIs — to any MCP-compatible coding agent. It implements the Agent Skills progressive disclosure pattern to deliver institutional Adobe development knowledge on demand, without redeploying or re-prompting context into every agent session.",
  "main": "actions/skills-mcp/index.js",
  "scripts": {
    "prebuild": "node scripts/generate-registry.js",
    "pretest": "node scripts/generate-registry.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "webpack",
    "deploy": "npm run build && aio app deploy",
    "undeploy": "aio app undeploy",
    "dev": "aio app run",
    "start": "node actions/skills-mcp/index.js",
    "lint": "eslint actions/",
    "format": "prettier --write actions/"
  },
  "dependencies": {
    "@adobe/aio-sdk": "^5.0.0",
    "@modelcontextprotocol/sdk": "1.17.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "jest": "^29.0.0",
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "babel-loader": "^9.2.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "@adobe/generator-app-remote-mcp-server-generic": "^0.1.8"
  },
  "keywords": [
    "adobe-io",
    "mcp",
    "model-context-protocol",
    "serverless",
    "template",
    "i/o-runtime"
  ],
  "engines": {
    "node": ">=18.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/YOUR_REPO_NAME.git"
  },
  "license": "MIT",
  "author": "David Benge <your.email@example.com>",
  "aio-app-builder-templates": [
    "@adobe/generator-app-remote-mcp-server-generic"
  ]
}
